---
layout: null
---
{%- assign _all = site.posts | concat: site.techic | concat: site.about_notes | sort: 'date' | reverse -%}
[
  {% for post in _all %}
    {
      "title"    : "{{ post.title | escape }}",
      "subtitle" : "{{ post.subtitle | escape }}",
      "tags"     : "{{ post.tags | join: ', ' }}",
      "url"      : "{{ site.baseurl }}{{ post.url }}",
      "date"     : "{{ post.date }}"
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
